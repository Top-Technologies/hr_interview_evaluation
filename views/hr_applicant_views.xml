<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_hr_applicant_evaluation_tab" model="ir.ui.view">
        <field name="name">hr.applicant.evaluation.tab</field>
        <field name="model">hr.applicant</field>
        <field name="inherit_id" ref="hr_recruitment.hr_applicant_view_form" />
        <field name="arch" type="xml">

            <xpath expr="//notebook" position="inside">
                <page string="Evaluation" name="evaluation_page">
                    <div class="o_interview_eval_banner alert alert-info mb-3" role="status">
                        <i class="fa fa-info-circle me-1" />
                        Fill in scores for each interviewer. The overall average score will be computed and displayed on the Job Position.
                    </div>
                    
                    <field name="evaluation_ids" nolabel="1">
                        <list string="Candidate Evaluations" editable="bottom">
                            <field name="rater_id" string="Interviewer" />
                            <field name="score_personality" string="Personality (10%)" />
                            <field name="score_hard_skill" string="Hard Skill (50%)" />
                            <field name="score_communication" string="Communication (30%)" />
                            <field name="score_teamwork" string="Team Work (10%)" />
                            <field name="score_total" string="Total" readonly="1" />
                            <field name="evaluation_date" string="Date" />
                            <field name="recommendations" string="Recommendations" optional="show" />
                        </list>
                    </field>

                    <group string="Overall Average Score Summary" class="mt-3">
                        <group>
                            <field name="evaluation_avg_personality" string="Average Personality (/10)" readonly="1" />
                            <field name="evaluation_avg_hard_skill" string="Average Hard Skill (/50)" readonly="1" />
                            <field name="evaluation_avg_communication" string="Average Communication (/30)" readonly="1" />
                            <field name="evaluation_avg_teamwork" string="Average Team Work (/10)" readonly="1" />
                        </group>
                        <group>
                            <field name="evaluation_avg_total" string="Average Total (/100)" readonly="1" />
                            <field name="evaluation_count" string="Total Interviewers" readonly="1" />
                        </group>
                    </group>
                </page>
            </xpath>

        </field>
    </record>

</odoo>